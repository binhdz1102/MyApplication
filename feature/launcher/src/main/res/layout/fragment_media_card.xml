<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.MyApplication.Card"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/card_inner_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/media_card_label"
            android:textColor="@color/launcher_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/songValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/launcher_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/appValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_chip_surface"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="@color/launcher_text_secondary"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/progressSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/currentTimeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/launcher_text_secondary"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/totalTimeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/launcher_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/previousButton"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_subtle_pill"
                android:contentDescription="@string/media_previous_cd"
                android:padding="14dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/launcher_text_primary" />

            <ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_chip_surface"
                android:contentDescription="@string/media_toggle_cd"
                android:padding="16dp"
                android:tint="@color/launcher_text_primary" />

            <ImageButton
                android:id="@+id/nextButton"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_subtle_pill"
                android:contentDescription="@string/media_next_cd"
                android:padding="14dp"
                android:src="@android:drawable/ic_media_next"
                android:tint="@color/launcher_text_primary" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
